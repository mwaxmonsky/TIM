@PACKAGE_INIT@

# TIMConfig.cmake
#
# Valid Find COMPONENTS:
#  * R4 - 32-bit library
#  * R8 - 64-bit library
#
# Imported targets provided:
#  * TIM::tim_r4 - real32 library target (if built with 32BIT=ON)
#  * TIM::tim_r8 - real64 library target (if built with 64BIT=ON)

include("${CMAKE_CURRENT_LIST_DIR}/tim-targets.cmake")
include(CMakeFindDependencyMacro)

find_dependency(MPI COMPONENTS C CXX Fortran)
list(APPEND CMAKE_MODULE_PATH ${CMAKE_CURRENT_LIST_DIR})
find_dependency(NetCDF COMPONENTS C Fortran)
list(REMOVE_ITEM CMAKE_MODULE_PATH ${CMAKE_CURRENT_LIST_DIR})
find_dependency(AMReX)

if(@OPENMP@)
  find_dependency(OpenMP COMPONENTS C Fortran)
endif()

set(TIMVersion "${PACKAGE_VERSION}")
set_and_check(TIM_INSTALL_PREFIX "${PACKAGE_PREFIX_DIR}")

# Component validation — mirrors FMS's fms-config.cmake pattern.
list(APPEND _possible_tim_components "R4" "R8")
foreach(_comp ${_possible_tim_components})
  set(_name_${_comp} ${_comp})
endforeach()

# R8 is the default component (MOM6 always uses double precision).
if(NOT TIM_FIND_COMPONENTS)
  list(APPEND _search_tim_components "R8")
endif()
foreach(_comp ${TIM_FIND_COMPONENTS})
  list(APPEND _search_tim_components ${_comp})
  if(NOT _name_${_comp})
    message(SEND_ERROR
      "TIM: COMPONENT ${_comp} is not a valid component. "
      "Valid components: ${_possible_tim_components}")
  endif()
endforeach()
list(REMOVE_DUPLICATES _search_tim_components)

# ON/OFF reflects whether TIM was built with 32BIT=ON
set(TIM_R4_FOUND 0)
if(@32BIT@)
  set(TIM_R4_FOUND 1)
  get_property(TIM_R4_LIBRARIES TARGET TIM::tim_r4 PROPERTY LOCATION)
  list(APPEND TIM_POSSIBLE_COMPONENTS R4)
endif()

# ON/OFF reflects whether TIM was built with 64BIT=ON
set(TIM_R8_FOUND 0)
if(@64BIT@)
  set(TIM_R8_FOUND 1)
  get_property(TIM_R8_LIBRARIES TARGET TIM::tim_r8 PROPERTY LOCATION)
  list(APPEND TIM_POSSIBLE_COMPONENTS R8)
endif()

check_required_components("TIM")

message(STATUS "Found TIM: \"${TIM_INSTALL_PREFIX}\" (Version: \"${TIMVersion}\")")
message(STATUS "TIM targets:")
foreach(_comp ${_search_tim_components})
  string(TOLOWER "${_comp}" _comp_lower)
  if(TIM_${_comp}_FOUND)
    message(STATUS "  - TIM::tim_${_comp_lower} [Lib: ${TIM_${_comp}_LIBRARIES}]")
  else()
    message(STATUS "  - TIM::tim_${_comp_lower} [COMPONENT ${_comp} NOT FOUND]")
  endif()
endforeach()
